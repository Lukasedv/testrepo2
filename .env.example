# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server-only secrets (NOT prefixed with NEXT_PUBLIC_) ──────────────────────

# Secret used to verify on-demand revalidation requests (POST /api/revalidate).
REVALIDATE_SECRET=change-me-to-a-random-secret

# Secret used to sign/verify session tokens.
SESSION_SECRET=change-me-to-another-random-secret

# Database connection URL (example shown for PostgreSQL).
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── Public variables (accessible in browser bundles) ─────────────────────────

# Base URL of the application (used for canonical URLs, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
